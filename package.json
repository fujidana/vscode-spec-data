{
	"publisher": "fujidana",
	"name": "spec-data",
	"displayName": "spec data",
	"description": "spec data file support for VS Code",
	"version": "2.2.0-alpha.0",
	"engines": {
		"vscode": "^1.110.0"
	},
	"categories": [
		"Programming Languages",
		"Visualization"
	],
	"keywords": [
		"X-ray diffraction",
		"synchrotron",
		"instrument control",
		"data acquisition"
	],
	"icon": "resources/icon.png",
	"license": "SEE LICENSE IN LICENSE",
	"bugs": {
		"url": "https://github.com/fujidana/vscode-spec-data/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/fujidana/vscode-spec-data.git"
	},
	"homepage": "https://github.com/fujidana/vscode-spec-data#readme",
	"activationEvents": [
		"onLanguage:spec-data",
		"onLanguage:csv-column",
		"onLanguage:csv-row",
		"onLanguage:dppmca",
		"onLanguage:chiplot",
		"onWebviewPanel:spec-data.preview"
	],
	"main": "./dist/node/extension.js",
	"browser": "./dist/web/extension.js",
	"l10n": "./l10n",
	"contributes": {
		"languages": [
			{
				"id": "spec-data",
				"aliases": [
					"spec data",
					"spec Standard Data Format",
					"spec scan"
				],
				"extensions": [
					".spec"
				],
				"firstLine": "^#F\\s+\\S.*$"
			},
			{
				"id": "csv-column",
				"aliases": [
					"CSV (numeric columns)"
				],
				"firstLine": "^#\\s*(.*)\\bmode\\s*:\\s*csv-column\\b"
			},
			{
				"id": "csv-row",
				"aliases": [
					"CSV (numeric rows)"
				],
				"firstLine": "^#\\s*(.*)\\bmode\\s*:\\s*csv-row\\b"
			},
			{
				"id": "dppmca",
				"aliases": [
					"Amptek MCA",
					"DP5 Digital Pulse Processor Multichannel Analyzers"
				],
				"extensions": [
					".mca"
				]
			},
			{
				"id": "chiplot",
				"aliases": [
					"chiplot"
				],
				"extensions": [
					".chi"
				],
				"firstLine": "^\\S+: (2-theta|Q-Space) Scan$"
			}
		],
		"grammars": [
			{
				"language": "spec-data",
				"scopeName": "source.spec-data",
				"path": "./syntaxes/specData.tmLanguage.json"
			},
			{
				"language": "csv-column",
				"scopeName": "source.csv",
				"path": "./syntaxes/csv.tmLanguage.json"
			},
			{
				"language": "csv-row",
				"scopeName": "source.csv",
				"path": "./syntaxes/csv.tmLanguage.json"
			},
			{
				"language": "dppmca",
				"scopeName": "source.dppmca",
				"path": "./syntaxes/dppmca.tmLanguage.json"
			},
			{
				"language": "chiplot",
				"scopeName": "source.chiplot",
				"path": "./syntaxes/chiplot.tmLanguage.json"
			}
		],
		"commands": [
			{
				"command": "spec-data.showPreview",
				"title": "%spec-data.commands.showPreview.title%",
				"category": "spec data",
				"icon": "$(graph-line)"
			},
			{
				"command": "spec-data.showPreviewToSide",
				"title": "%spec-data.commands.showPreviewToSide.title%",
				"category": "spec data",
				"icon": "$(open-preview)"
			},
			{
				"command": "spec-data.showLockedPreview",
				"title": "%spec-data.commands.showLockedPreview.title%",
				"category": "spec data"
			},
			{
				"command": "spec-data.showLockedPreviewToSide",
				"title": "%spec-data.commands.showLockedPreviewToSide.title%",
				"category": "spec data"
			},
			{
				"command": "spec-data.showSource",
				"title": "%spec-data.commands.showSource.title%",
				"category": "spec data",
				"icon": "$(go-to-file)"
			},
			{
				"command": "spec-data.refreshPreview",
				"title": "%spec-data.commands.refreshPreview.title%",
				"category": "spec data",
				"icon": "$(refresh)"
			},
			{
				"command": "spec-data.toggleMultipleSelection",
				"title": "%spec-data.commands.toggleMultipleSelection.title%",
				"category": "spec data",
				"icon": "$(list-unordered)"
			},
			{
				"command": "spec-data.toggleRightAxis",
				"title": "%spec-data.commands.toggleRightAxis.title%",
				"category": "spec data",
				"icon": "$(list-selection)"
			},
			{
				"command": "spec-data.togglePreviewLock",
				"title": "%spec-data.commands.togglePreviewLock.title%",
				"category": "spec data",
				"icon": "$(lock)"
			}
		],
		"menus": {
			"explorer/context": [
				{
					"command": "spec-data.showPreview",
					"when": "resourceLangId =~ /^(spec-data|csv-(row|column)|dppmca|chiplot)$/",
					"group": "navigation"
				},
				{
					"command": "spec-data.showLockedPreview",
					"when": "resourceLangId =~ /^(spec-data|csv-(row|column)|dppmca|chiplot)$/",
					"group": "navigation"
				}
			],
			"editor/title": [
				{
					"command": "spec-data.showPreviewToSide",
					"alt": "spec-data.showPreview",
					"when": "editorLangId =~ /^(spec-data|csv-(row|column)|dppmca|chiplot)$/",
					"group": "navigation"
				},
				{
					"command": "spec-data.showLockedPreviewToSide",
					"alt": "spec-data.showLockedPreview",
					"when": "editorLangId =~ /^(spec-data|csv-(row|column)|dppmca|chiplot)$/",
					"group": "2_specdata"
				},
				{
					"command": "spec-data.showSource",
					"group": "navigation",
					"when": "resourceScheme == webview-panel && activeWebviewPanelId == 'spec-data.preview'"
				},
				{
					"command": "spec-data.toggleMultipleSelection",
					"alt": "spec-data.toggleRightAxis",
					"group": "navigation",
					"when": "resourceScheme == webview-panel && activeWebviewPanelId == 'spec-data.preview'"
				},
				{
					"command": "spec-data.refreshPreview",
					"group": "2_specdata",
					"when": "resourceScheme == webview-panel && activeWebviewPanelId == 'spec-data.preview'"
				},
				{
					"command": "spec-data.togglePreviewLock",
					"group": "2_specdata",
					"when": "resourceScheme == webview-panel && activeWebviewPanelId == 'spec-data.preview'"
				}
			],
			"editor/title/context": [
				{
					"command": "spec-data.showPreview",
					"when": "editorLangId =~ /^(spec-data|csv-(row|column)|dppmca|chiplot)$/",
					"group": "3_preview"
				}
			],
			"commandPalette": [
				{
					"command": "spec-data.showPreview",
					"when": "editorLangId =~ /^(spec-data|csv-(row|column)|dppmca|chiplot)$/"
				},
				{
					"command": "spec-data.showPreviewToSide",
					"when": "editorLangId =~ /^(spec-data|csv-(row|column)|dppmca|chiplot)$/"
				},
				{
					"command": "spec-data.showLockedPreview",
					"when": "editorLangId =~ /^(spec-data|csv-(row|column)|dppmca|chiplot)$/"
				},
				{
					"command": "spec-data.showLockedPreviewToSide",
					"when": "editorLangId =~ /^(spec-data|csv-(row|column)|dppmca|chiplot)$/"
				},
				{
					"command": "spec-data.showSource",
					"when": "resourceScheme == webview-panel && activeWebviewPanelId == 'spec-data.preview'"
				},
				{
					"command": "spec-data.refreshPreview",
					"when": "resourceScheme == webview-panel && activeWebviewPanelId == 'spec-data.preview'"
				},
				{
					"command": "spec-data.toggleMultipleSelection",
					"when": "resourceScheme == webview-panel && activeWebviewPanelId == 'spec-data.preview'"
				},
				{
					"command": "spec-data.toggleRightAxis",
					"when": "resourceScheme == webview-panel && activeWebviewPanelId == 'spec-data.preview'"
				},
				{
					"command": "spec-data.togglePreviewLock",
					"when": "resourceScheme == webview-panel && activeWebviewPanelId == 'spec-data.preview'"
				}
			]
		},
		"keybindings": [
			{
				"command": "spec-data.showPreview",
				"key": "ctrl+shift+v",
				"mac": "cmd+shift+v",
				"when": "!notebookEditorFocused && editorLangId =~ /^(spec-data|csv-(row|column)|dppmca|chiplot)$/"
			},
			{
				"command": "spec-data.showPreviewToSide",
				"key": "ctrl+k v",
				"mac": "cmd+k v",
				"when": "!notebookEditorFocused && editorLangId =~ /^(spec-data|csv-(row|column)|dppmca|chiplot)$/"
			}
		],
		"configuration": {
			"title": "spec data",
			"properties": {
				"spec-data.preview.scrollEditorWithPreview": {
					"type": "boolean",
					"default": true,
					"scope": "window",
					"description": "%spec-data.configuration.preview.scrollEditorWithPreview.description%"
				},
				"spec-data.preview.scrollPreviewWithEditor": {
					"type": "boolean",
					"default": true,
					"scope": "window",
					"description": "%spec-data.configuration.preview.scrollPreviewWithEditor.description%"
				},
				"spec-data.preview.smoothScrolling": {
					"type": "boolean",
					"default": false,
					"scope": "window",
					"markdownDescription": "%spec-data.configuration.preview.smoothScrolling.description%"
				},
				"spec-data.preview.retainContextWhenHidden": {
					"type": "boolean",
					"default": false,
					"scope": "window",
					"description": "%spec-data.configuration.preview.retainContextWhenHidden.description%"
				},
				"spec-data.preview.applyContentSecurityPolicy": {
					"type": "boolean",
					"default": true,
					"scope": "resource",
					"description": "%spec-data.configuration.preview.applyContentSecurityPolicy.description%",
					"markdownDeprecationMessage": "**Deprecated**: This setting will be removed in a future release. The CSP will always be applied to the preview."
				},
				"spec-data.preview.autoLockGroup": {
					"type": "boolean",
					"default": false,
					"scope": "window",
					"markdownDescription": "%spec-data.configuration.preview.autoLockGroup.description%",
					"tags": [
						"preview"
					]
				},
				"spec-data.preview.plot.maximumNumberOfPlots": {
					"type": "integer",
					"default": 25,
					"minimum": 0,
					"scope": "language-overridable",
					"description": "%spec-data.configuration.preview.plot.maximumNumberOfPlots.description%"
				},
				"spec-data.preview.plot.height": {
					"type": "number",
					"default": 400,
					"minimum": 200,
					"scope": "language-overridable",
					"description": "%spec-data.configuration.preview.plot.height.description%"
				},
				"spec-data.preview.plot.colorScale": {
					"type": "string",
					"default": "RdBu",
					"enum": [
						"Blackbody",
						"Bluered",
						"Blues",
						"Cividis",
						"Earth",
						"Electric",
						"Greens",
						"Greys",
						"Hot",
						"Jet",
						"Picnic",
						"Portland",
						"Rainbow",
						"RdBu",
						"Reds",
						"Viridis",
						"YlGnBu",
						"YlOrRd"
					],
					"enumItemLabels": [
						"",
						"",
						"",
						"",
						"",
						"",
						"",
						"",
						"",
						"",
						"",
						"",
						"",
						"Red-Blue",
						"",
						"",
						"Yellow-Green-Blue",
						"Yellow-Orange-Red"
					],
					"scope": "language-overridable",
					"description": "%spec-data.configuration.preview.plot.colorScale.description%",
					"tags": [
						"preview"
					]
				},
				"spec-data.preview.plot.traceTemplate": {
					"type": "object",
					"scope": "language-overridable",
					"markdownDescription": "%spec-data.configuration.preview.plot.traceTemplate.description%",
					"markdownDeprecationMessage": "**Deprecated**: Please use `#spec-data.preview.plot.template.data#` instead."
				},
				"spec-data.preview.plot.template.data": {
					"type": "object",
					"scope": "language-overridable",
					"markdownDescription": "%spec-data.configuration.preview.plot.template.data.description%",
					"properties": {
						"light": {
							"type": "object",
							"properties": {
								"scatter": {
									"type": "array"
								},
								"heatmap": {
									"type": "array"
								},
								"contour": {
									"type": "array"
								}
							},
							"additionalProperties": false
						},
						"dark": {
							"type": "object",
							"properties": {
								"scatter": {
									"type": "array"
								},
								"heatmap": {
									"type": "array"
								},
								"contour": {
									"type": "array"
								}
							},
							"additionalProperties": false
						},
						"highContrast": {
							"type": "object",
							"properties": {
								"scatter": {
									"type": "array"
								},
								"heatmap": {
									"type": "array"
								},
								"contour": {
									"type": "array"
								}
							},
							"additionalProperties": false
						},
						"highContrastLight": {
							"type": "object",
							"properties": {
								"scatter": {
									"type": "array"
								},
								"heatmap": {
									"type": "array"
								},
								"contour": {
									"type": "array"
								}
							},
							"additionalProperties": false
						},
						"additionalProperties": false
					}
				},
				"spec-data.preview.plot.layoutTemplate": {
					"type": "object",
					"scope": "language-overridable",
					"markdownDescription": "%spec-data.configuration.preview.plot.layoutTemplate.description%",
					"markdownDeprecationMessage": "**Deprecated**: Please use `#spec-data.preview.plot.template.layout#` instead."
				},
				"spec-data.preview.plot.template.layout": {
					"type": "object",
					"scope": "language-overridable",
					"markdownDescription": "%spec-data.configuration.preview.plot.template.layout.description%",
					"additionalProperties": false,
					"properties": {
						"light": {
							"type": "object"
						},
						"dark": {
							"type": "object"
						},
						"highContrast": {
							"type": "object"
						},
						"highContrastLight": {
							"type": "object"
						}
					}
				},
				"spec-data.preview.plot.enableMultipleSelection": {
					"type": "boolean",
					"default": false,
					"scope": "window",
					"description": "%spec-data.configuration.preview.plot.enableMultipleSelection.description%"
				},
				"spec-data.preview.plot.enableRightAxis": {
					"type": "boolean",
					"default": false,
					"scope": "window",
					"description": "%spec-data.configuration.preview.plot.enableRightAxis.description%"
				},
				"spec-data.preview.table.hide": {
					"type": "boolean",
					"default": true,
					"scope": "language-overridable",
					"description": "%spec-data.configuration.preview.table.hide.description%"
				},
				"spec-data.preview.table.columnsPerLine": {
					"type": "number",
					"default": 8,
					"minimum": 1,
					"scope": "language-overridable",
					"description": "%spec-data.configuration.preview.table.columnsPerLine.description%"
				},
				"spec-data.preview.table.headerType": {
					"type": "string",
					"default": "Mnemonic",
					"enum": [
						"Name",
						"Mnemonic",
						"None"
					],
					"scope": "language-overridable",
					"description": "%spec-data.configuration.preview.table.headerType.description%"
				}
			}
		},
		"configurationDefaults": {
			"[dppmca]": {
				"files.encoding": "windows1252"
			}
		}
	},
	"capabilities": {
		"virtualWorkspaces": true,
		"untrustedWorkspaces": {
			"supported": "limited",
			"description": "%spec-data.capabilities.untrustedWorkspaces.description%",
			"restrictedConfigurations": [
				"spec-data.preview.plot.template.data",
				"spec-data.preview.plot.template.layout",
				"spec-data.preview.applyContentSecurityPolicy"
			]
		}
	},
	"scripts": {
		"vscode:prepublish": "pnpm run package && pnpm run js-yaml && pnpm run bundle-plotly",
		"compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
		"watch": "npm-run-all -p watch:*",
		"watch:esbuild": "node esbuild.js --watch",
		"watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
		"package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
		"compile-tests": "tsc -p . --outDir out",
		"watch-tests": "tsc -p . -w --outDir out",
		"pretest": "pnpm run compile && pnpm run compile-tests",
		"pretest-web": "pnpm run compile",
		"check-types": "tsc --noEmit",
		"lint": "eslint src",
		"test": "vscode-test",
		"test-web": "vscode-test-web --browserType=chromium --extensionDevelopmentPath=. --extensionTestsPath=dist/web/test/extensionTests.js",
		"run-in-browser": "vscode-test-web --browserType=chromium --extensionDevelopmentPath=. .",
		"js-yaml": "npm-run-all js-yaml:*",
		"js-yaml:spec-data": "js-yaml syntaxes/specData.tmLanguage.yaml > syntaxes/specData.tmLanguage.json",
		"js-yaml:csv": "js-yaml syntaxes/csv.tmLanguage.yaml > syntaxes/csv.tmLanguage.json",
		"js-yaml:dppmca": "js-yaml syntaxes/dppmca.tmLanguage.yaml > syntaxes/dppmca.tmLanguage.json",
		"js-yaml:chiplot": "js-yaml syntaxes/chiplot.tmLanguage.yaml > syntaxes/chiplot.tmLanguage.json",
		"l10n-export": "npx @vscode/l10n-dev export -o ./l10n ./src",
		"bundle-plotly": "npm install --prefix ./dist/preview --no-save plotly.js-cartesian-dist-min@3.4.0"
	},
	"devDependencies": {
		"@esbuild-plugins/node-globals-polyfill": "^0.2.3",
		"@types/assert": "^1.5.11",
		"@types/mocha": "^10.0.10",
		"@types/node": "22.x",
		"@types/plotly.js": "^3.0.10",
		"@types/vscode": "^1.110.0",
		"@types/vscode-webview": "^1.57.5",
		"@vscode/test-cli": "^0.0.12",
		"@vscode/test-electron": "^2.5.2",
		"@vscode/test-web": "^0.0.80",
		"assert": "^2.1.0",
		"esbuild": "^0.27.3",
		"eslint": "^9.39.3",
		"glob": "^13.0.6",
		"js-yaml": "^4.1.1",
		"mocha": "^11.7.5",
		"npm-run-all": "^4.1.5",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1"
	},
	"dependencies": {
		"minimatch": "^10.2.4"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@playwright/browser-chromium",
			"esbuild"
		]
	}
}